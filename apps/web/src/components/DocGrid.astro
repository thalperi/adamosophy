---
import { getDocs } from '../../lib/docs';

interface Props {
  viewMode?: 'card' | 'list';
}

const { viewMode = 'card' } = Astro.props;
const docs = await getDocs();
---

<div class="docs-grid" data-view-mode={viewMode}>
  {docs.map((doc) => {
    const slug = doc.id.replace('.md', '');
    const hasImage = doc.data.image && doc.data.image.trim() !== '';
    
    return (
      <a href={`/adamosophy/docs/${slug}`} class="doc-card">
        {hasImage && (
          <div class="card-image">
            <img src={doc.data.image} alt={doc.data.title} loading="lazy" />
          </div>
        )}
        <div class="card-content">
          <h2>{doc.data.title}</h2>
          {doc.data.description && <p>{doc.data.description}</p>}
        </div>
      </a>
    );
  })}
</div>

<style>
  .docs-grid {
    display: grid;
    gap: var(--space-lg);
  }
  
  .docs-grid[data-view-mode="card"] {
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }
  
  .docs-grid[data-view-mode="list"] {
    grid-template-columns: 1fr;
  }
  
  .doc-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    overflow: hidden;
  }
  
  .docs-grid[data-view-mode="list"] .doc-card {
    flex-direction: row;
    align-items: center;
    padding: var(--space-md);
  }
  
  .doc-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }
  
  .card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background-color: var(--color-bg-secondary);
  }
  
  .docs-grid[data-view-mode="list"] .card-image {
    width: 120px;
    height: 80px;
    flex-shrink: 0;
    margin-right: var(--space-md);
  }
  
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .card-content {
    padding: var(--space-md);
    flex: 1;
  }
  
  .docs-grid[data-view-mode="list"] .card-content {
    padding: 0;
  }
  
  .card-content h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }
  
  .docs-grid[data-view-mode="list"] .card-content h2 {
    font-size: 1rem;
    margin-bottom: 0;
  }
  
  .card-content p {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  
  .docs-grid[data-view-mode="list"] .card-content p {
    display: none;
  }
</style>
