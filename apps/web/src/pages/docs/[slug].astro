---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { getDocs } from '../../lib/docs';

export async function getStaticPaths() {
  const docs = await getDocs();
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const Content = doc.Content;
---

<DocsLayout title={`${doc.data.title} | Adamosophy`}>
  <article class="doc-content">
    <h1>{doc.data.title}</h1>
    <Content />
  </article>
</DocsLayout>

<style>
  /* Documentation content styling */
  .doc-content {
    max-width: 800px;
  }

  .doc-content h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e0e0e0;
  }

  .doc-content h2 {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .doc-content h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .doc-content p {
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .doc-content ul,
  .doc-content ol {
    margin-bottom: 1.25rem;
    padding-left: 2rem;
  }

  .doc-content li {
    margin-bottom: 0.5rem;
  }

  .doc-content a {
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .doc-content a:hover {
    border-bottom-color: var(--color-primary);
  }

  .doc-content code {
    background: #f5f5f5;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: 'Monaco', 'Consolas', monospace;
    font-size: 0.9em;
    color: #c7254e;
  }

  .doc-content pre {
    background: #263238;
    color: #eceff1;
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .doc-content pre code {
    background: none;
    color: inherit;
    padding: 0;
  }

  .doc-content blockquote {
    border-left: 4px solid var(--color-primary);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    color: #616161;
    font-style: italic;
  }

  .doc-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
  }
</style>
