---
import TopNav from '../components/TopNav.astro';
import { getDocs } from '../lib/docs';

const docItems = await getDocs();
---

<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="description" content={Astro.props.description || 'Adamosophy - Social Wisdom Through Technology'} />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<title>{Astro.props.title}</title>
<style>
:root {
--primary: #00838F;
--primary-dark: #005662;
--secondary: #00ACC1;
--text-primary: #212121;
--text-secondary: #757575;
--text-muted: #9E9E9E;
--text-light: #BDBDBD;
--bg-color: #FAFAFA;
--card-bg: #FFFFFF;
--border-color: #E0E0E0;
--badge-bg: #ECEFF1;
--badge-text: #546E7A;
--sidebar-width: 280px;
--header-height: 64px;
}

* {
box-sizing: border-box;
margin: 0;
padding: 0;
}

body {
font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
background-color: var(--bg-color);
color: var(--text-primary);
line-height: 1.6;
}

a {
color: var(--primary);
text-decoration: none;
}

.layout-wrapper {
display: flex;
flex-direction: column;
min-height: 100vh;
}

.main-content {
flex: 1;
margin-top: var(--header-height);
}

@media (min-width: 768px) {
.main-content {
margin-left: var(--sidebar-width);
}
}
</style>
</head>
<body>
<div class="layout-wrapper">
<TopNav />
<aside class="sidebar">
<nav>
<ul>
{docItems.map((doc) => (
<li>
<a href={`/adamosophy/docs/${doc.slug}`}>{doc.title}</a>
</li>
))}
</ul>
</nav>
</aside>
<main class="main-content">
<slot />
</main>
</div>
</body>
</html>

<style>
.sidebar {
position: fixed;
top: var(--header-height);
left: 0;
bottom: 0;
width: var(--sidebar-width);
background: #f5f5f5;
border-right: 1px solid var(--border-color);
padding: 1.5rem;
overflow-y: auto;
display: none;
}

@media (min-width: 768px) {
.sidebar {
display: block;
}
}

.sidebar nav ul {
list-style: none;
}

.sidebar nav li {
margin-bottom: 0.5rem;
}

.sidebar nav a {
display: block;
padding: 0.75rem 1rem;
color: var(--text-primary);
text-decoration: none;
border-radius: 6px;
transition: background-color 0.2s;
}

.sidebar nav a:hover {
background: #e8e8e8;
}
</style>
