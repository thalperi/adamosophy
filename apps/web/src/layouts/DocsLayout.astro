---
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';
import 'github-markdown-css/github-markdown.css';

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const currentSlug = pathSegments[pathSegments.length - 1] || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Social wisdom through technology for created humankind" />
    <title>Adamosophy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="app-grid">
      <TopNav />
      
      <aside class="sidebar">
        <Sidebar currentSlug={currentSlug} />
      </aside>

      <main class="main-content">
        <slot />
      </main>
      
      <footer class="footer">
        <p>&copy; 2025 Adamosophy. All rights reserved.</p>
      </footer>
    </div>
  </body>
</html>

<style>
  .app-grid {
    min-height: 100vh;
    display: grid;
    grid-template-areas:
      "header header"
      "sidebar main"
      "footer footer";
    grid-template-columns: var(--sidebar-width) 1fr;
    grid-template-rows: var(--header-height) 1fr auto;
    gap: 0;
    height: 100vh;
    overflow: hidden;
  }

  .sidebar {
    grid-area: sidebar;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: var(--grid-gap);
    padding: var(--grid-gap-lg);
    background-color: var(--color-bg-secondary);
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
  }

  .main-content {
    grid-area: main;
    padding: var(--grid-gap-lg);
    overflow-y: auto;
    min-height: 0;
  }

  .main-content > ::slotted(*) {
    height: 100%;
  }

  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }

    .sidebar.open {
      display: grid;
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 99;
      background-color: var(--color-bg-secondary);
    }
  }
</style>
