---
import TopNav from '../components/TopNav.astro';
import { getDocs } from '../lib/docs';
import '../styles/global.css';

const docs = await getDocs();
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const currentSlug = pathSegments[pathSegments.length - 1] || '';
const base = Astro.site?.pathname?.replace(/\/$/, '') || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Social wisdom through technology for created humankind" />
    <title>Adamosophy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="app-grid">
      <TopNav />
      
      <aside class="sidebar">
        <nav>
          <h3>Documentation</h3>
          <ul>
            {docs.map((doc) => (
              <li>
                <a 
                  href={`${base}docs/${doc.id}`} 
                  class:list={{ active: doc.id === currentSlug }}
                >
                  {doc.data.title}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <main class="main-content">
        <slot />
      </main>
      
      <footer class="footer">
        <p>&copy; 2025 Adamosophy. All rights reserved.</p>
      </footer>
    </div>
  </body>
</html>

<style>
  .app-grid {
    min-height: 100vh;
  }

  .sidebar {
    grid-area: sidebar;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: var(--grid-gap);
    padding: var(--grid-gap-lg);
    background-color: var(--color-bg-secondary);
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
  }

  .sidebar nav ul {
    list-style: none;
  }

  .sidebar nav li {
    margin-bottom: 0;
  }

  .sidebar nav a {
    display: block;
    padding: var(--space-sm) var(--space-md);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: all 0.2s ease;
  }

  .sidebar nav a:hover {
    color: var(--color-primary);
    background-color: var(--color-bg);
  }

  .sidebar nav a.active {
    color: var(--color-primary);
    font-weight: 600;
    background-color: var(--color-bg);
  }

  .main-content {
    grid-area: main;
    padding: var(--grid-gap-lg);
    overflow-y: auto;
    min-height: 0;
  }

  .main-content > ::slotted(*) {
    height: 100%;
  }

  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }

    .sidebar.open {
      display: grid;
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 99;
      background-color: var(--color-bg-secondary);
    }
  }
</style>
