---
import TopNav from '../components/TopNav.astro';
import { getDocs } from '../lib/docs';
import '../styles/global.css';

const docs = await getDocs();
const currentSlug = Astro.url.pathname.split('/').pop() || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Social wisdom through technology for created humankind" />
    <title>Adamosophy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="app-grid">
      <TopNav />
      
      <aside class="sidebar">
        <nav>
          <ul>
            {docs.map((doc) => (
              <li>
                <a 
                  href={`/adamosophy/docs/${doc.slug}`} 
                  class:list={{ active: doc.slug === currentSlug }}
                >
                  {doc.title}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <main class="main-content">
        <slot />
      </main>
      
      <footer class="footer">
        <p>&copy; 2025 Adamosophy. All rights reserved.</p>
      </footer>
    </div>
  </body>
</html>

<style>
  .sidebar {
    grid-area: sidebar;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: var(--grid-gap);
    padding: var(--grid-gap-lg);
    background-color: var(--color-bg-secondary);
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
  }

  .sidebar nav ul {
    list-style: none;
  }

  .sidebar nav li {
    margin-bottom: 0;
  }

  .sidebar nav a {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: all 0.2s ease;
  }

  .sidebar nav a:hover {
    color: var(--color-primary);
    background-color: var(--color-bg);
  }

  .sidebar nav a.active {
    color: var(--color-primary);
    font-weight: 600;
    background-color: var(--color-bg);
  }

  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }

    .sidebar.open {
      display: grid;
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 99;
      background-color: var(--color-bg-secondary);
    }
  }
</style>
